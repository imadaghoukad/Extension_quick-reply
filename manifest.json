{
  "manifest_version": 3,
  "name": "Gemini Quick Reply",
  "version": "1.0.0",
  "description": "Adds a Quick Reply button to messages in the Gemini web...",
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}